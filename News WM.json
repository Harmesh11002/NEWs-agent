    {
      "parameters": {
        "jsCode": "// Grab the raw articles directly from the source API node safely\nconst rawArticles = $('Fetch AI News from NewsAPI').first().json.articles || [];\n\n// Loop over all incoming items from the workflow loop\nfor (let i = 0; i < $input.all().length; i++) {\n  let item = $input.all()[i];\n\n  // Set standard text fallbacks\n  item.json.title = item.json.title || \"No Title Found\";\n  item.json.url = item.json.url || \"No URL Found\";\n  item.json.summary = item.json.summary || item.json.output || \"No Summary Generated\";\n\n  // Find the matching article from NewsAPI using a partial title match\n  const matchedArticle = rawArticles.find(article => \n    article.title && item.json.title.toLowerCase().includes(article.title.toLowerCase().substring(0, 15))\n  );\n\n  // If a match is found and has an image, use it; otherwise, use a unique random fallback number\n  if (matchedArticle && matchedArticle.urlToImage) {\n    item.json.urlToImage = matchedArticle.urlToImage;\n  } else {\n    item.json.urlToImage = `https://picsum.photos/600/300?random=${Math.floor(Math.random() * 1000)}`;\n  }\n}\n\nreturn $input.all();"
      },
