    {
      "parameters": {
        "mode": "runOnceForEachItem",
        "jsCode": "// Get the AI text\nconst aiOutput = item.json.content?.parts?.[0]?.text || \"\";\n\n// Attempt to parse the AI output\nlet summaryData = {};\ntry {\n  // Clean the string and parse\n  const cleanJson = aiOutput.replace(/\\\\/g, \"\").replace(/\\n/g, \"\");\n  summaryData = JSON.parse(cleanJson);\n} catch (e) {\n  summaryData = { Title: \"No Title\", Summary: aiOutput };\n}\n\n// Return the data mapping the capitalized keys from your AI\nreturn {\n  json: {\n    title: $('Limit to Top 2').item.json.articles.title || summaryData.Title || \"No Title\",\n    url:$('Limit to Top 2').item.json.articles.url || summaryData.URL || \"No URL Found\",\n    summary:$json.output || summaryData.Summary || aiOutput\n  }\n};"
      },
